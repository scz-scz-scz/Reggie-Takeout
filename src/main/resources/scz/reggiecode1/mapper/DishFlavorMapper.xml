<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="scz.reggiecode1.mapper.DishFlavorMapper">
    <select id="getMaxId" resultType="java.lang.Long">
        select max(id) from dish_flavor;
    </select>

    <insert id="save">
        insert into dish_flavor (id, dish_id, name, value, create_time, update_time, create_user, update_user) VALUES (#{id},#{dishId},#{name},#{value},#{createTime},#{updateTime},#{createUser},#{updateUser});
    </insert>

    <select id="list" resultType="scz.reggiecode1.entity.DishFlavor">
        select * from dish_flavor where dish_id=#{dishId};
    </select>

    <update id="predelete">
        update dish_flavor set dish_flavor.update_time=#{updateTime},dish_flavor.update_user=#{updateUser},is_deleted=#{isDeleted} where dish_id=#{dishId};
    </update>

    <update id="update">
        update dish_flavor
        <set>
            name=#{name},value=#{value},update_time=#{updateTime},update_user=#{updateUser},is_deleted=#{isDeleted}
        </set>
        where id=#{id};
    </update>

    <delete id="delete">
        delete from dish_flavor where dish_id=#{dishId} and is_deleted=1;
    </delete>
</mapper>